{
  "module": {
    "name": "weather",
    "version": "1.0.0",
    "description": "Weather tool service using NOAA National Weather Service API",
    "author": "CIRIS Team",
    "safe_domain": true
  },
  "services": [{
    "type": "TOOL",
    "priority": "NORMAL",
    "class": "weather.service.WeatherToolService",
    "capabilities": [
      "weather:current",
      "weather:forecast",
      "weather:alerts",
      "domain:weather"
    ]
  }],
  "capabilities": [
    "weather:current",
    "weather:forecast",
    "weather:alerts",
    "domain:weather"
  ],
  "dependencies": {
    "protocols": [
      "ciris_engine.protocols.services.runtime.tool.ToolServiceProtocol"
    ],
    "schemas": [
      "ciris_engine.schemas.adapters.tools"
    ],
    "external": {
      "aiohttp": ">=3.8.0"
    }
  },
  "interactive_config": {
    "required": false,
    "workflow_type": "simple_config",
    "steps": [
      {
        "step_id": "user_agent",
        "step_type": "input",
        "title": "NOAA User Agent",
        "description": "Enter a user agent for NOAA Weather API (required by NOAA)",
        "required": true,
        "fields": [
          {
            "name": "user_agent",
            "label": "User Agent String",
            "type": "string",
            "required": true,
            "default": "CIRIS/1.0 (contact@ciris.ai)",
            "description": "Format: AppName/Version (contact@email.com)"
          }
        ]
      },
      {
        "step_id": "owm_api_key",
        "step_type": "input",
        "title": "OpenWeatherMap API Key (Optional)",
        "description": "For international coverage. Leave blank for NOAA only (US). Get free key at openweathermap.org",
        "required": false,
        "fields": [
          {
            "name": "owm_api_key",
            "label": "OpenWeatherMap API Key",
            "type": "password",
            "required": false,
            "description": "Leave blank to skip"
          }
        ]
      },
      {
        "step_id": "select_units",
        "step_type": "input",
        "title": "Temperature Units",
        "description": "Select your preferred temperature and wind speed units",
        "required": false,
        "fields": [
          {
            "name": "units",
            "label": "Units",
            "type": "select",
            "required": false,
            "default": "imperial",
            "options": [
              {"value": "imperial", "label": "Imperial (°F, mph)", "description": "Fahrenheit and miles per hour"},
              {"value": "metric", "label": "Metric (°C, m/s)", "description": "Celsius and meters per second"},
              {"value": "kelvin", "label": "Kelvin", "description": "Scientific units"}
            ]
          }
        ]
      },
      {
        "step_id": "default_location",
        "step_type": "input",
        "title": "Default Location (Optional)",
        "description": "Set a default location for weather queries",
        "required": false,
        "fields": [
          {
            "name": "default_location",
            "label": "Default Location",
            "type": "string",
            "required": false,
            "description": "Enter as latitude,longitude (e.g., 40.7128,-74.0060 for NYC)"
          }
        ]
      },
      {
        "step_id": "update_interval",
        "step_type": "input",
        "title": "Cache Interval (Optional)",
        "description": "How often to refresh cached weather data",
        "required": false,
        "fields": [
          {
            "name": "update_interval",
            "label": "Update Interval",
            "type": "select",
            "required": false,
            "default": "300",
            "options": [
              {"value": "60", "label": "1 minute", "description": "Most frequent updates"},
              {"value": "300", "label": "5 minutes (Recommended)", "description": "Good balance"},
              {"value": "600", "label": "10 minutes", "description": "Less frequent"},
              {"value": "1800", "label": "30 minutes", "description": "Minimal API usage"}
            ]
          }
        ]
      },
      {
        "step_id": "confirm",
        "step_type": "confirm",
        "title": "Confirm Configuration",
        "description": "Review and apply your Weather service configuration"
      }
    ],
    "completion_method": "apply_config"
  },
  "exports": {
    "service_class": "weather.service.WeatherToolService",
    "configurable": "weather.configurable.WeatherConfigurableAdapter",
    "capabilities": [
      "weather:current",
      "weather:forecast",
      "weather:alerts",
      "domain:weather"
    ]
  },
  "configuration": {
    "noaa_user_agent": {
      "type": "string",
      "env": "CIRIS_NOAA_USER_AGENT",
      "default": "CIRIS/1.0 (contact@ciris.ai)",
      "description": "User agent for NOAA Weather API (required)"
    },
    "openweathermap_api_key": {
      "type": "string",
      "env": "CIRIS_OPENWEATHERMAP_API_KEY",
      "default": null,
      "description": "Optional OpenWeatherMap API key for fallback (international locations)"
    },
    "units": {
      "type": "string",
      "env": "CIRIS_WEATHER_UNITS",
      "default": "imperial",
      "description": "Temperature and wind speed units (imperial, metric, kelvin)"
    },
    "default_location": {
      "type": "string",
      "env": "CIRIS_WEATHER_DEFAULT_LOCATION",
      "default": null,
      "description": "Default location as 'latitude,longitude' or city name"
    },
    "update_interval": {
      "type": "integer",
      "env": "CIRIS_WEATHER_UPDATE_INTERVAL",
      "default": 300,
      "description": "Cache update interval in seconds (minimum 60)"
    }
  },
  "metadata": {
    "primary_api": "NOAA National Weather Service",
    "fallback_api": "OpenWeatherMap",
    "requires_api_key": false,
    "safe_domain": "weather",
    "data_source": true,
    "data_source_type": "rest"
  }
}
