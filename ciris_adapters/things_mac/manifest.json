{
  "module": {
    "name": "things_mac",
    "version": "1.0.0",
    "description": "Manage Things 3 via the `things` CLI on macOS (add/update projects+todos, read/search/list from local database).",
    "author": "CIRIS Team (converted from Clawdbot)",
    "homepage": "https://github.com/ossianhempel/things3-cli"
  },
  "platform_requirements": [
    "desktop_cli"
  ],
  "platform_requirements_rationale": "Requires CLI tools only available on desktop",
  "services": [
    {
      "type": "TOOL",
      "priority": "NORMAL",
      "class": "things_mac.service.ThingsMacToolService",
      "capabilities": [
        "tool:things_mac",
        "requires:binaries"
      ]
    }
  ],
  "capabilities": [
    "tool:things_mac",
    "requires:binaries"
  ],
  "dependencies": {
    "protocols": [
      "ciris_engine.protocols.services.runtime.tool.ToolServiceProtocol"
    ],
    "schemas": [
      "ciris_engine.schemas.adapters.tools"
    ]
  },
  "exports": {
    "service_class": "things_mac.service.ThingsMacToolService"
  },
  "configuration": {},
  "cli_dependencies": [
    "things_mac"
  ]
}
